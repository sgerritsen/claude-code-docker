{
  "name": "Claude Code (Azure Foundry)",
  "build": {
    "context": "..",
    "dockerfile": "../Dockerfile"
  },
  "workspaceFolder": "/workspace",
  "workspaceMount": "source=${localWorkspaceFolder}/workspace,target=/workspace,type=bind,consistency=cached",

  "mounts": [
    "source=~/.claude,target=/home/claude/.claude,type=bind,consistency=cached",
    "source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind,consistency=cached"
  ],

  "remoteUser": "claude",
  "updateRemoteUserUID": true,

  "runArgs": [
    "--init",
    "--env-file", "${localWorkspaceFolder}/.devcontainer/.env",
    "--add-host=host.docker.internal:host-gateway",
    "--network=development-projects_default"
  ],
  "containerEnv": {
    "DISABLE_TELEMETRY": "1"
  },

  "overrideCommand": true,

  "customizations": {
    "jetbrains": {
      "plugins": [
        "org.jetbrains.plugins.terminal",
        "com.intellij.modules.lang"
      ]
    }
  }
}